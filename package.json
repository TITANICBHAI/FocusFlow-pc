{
  "name": "focusflow",
  "version": "1.0.0",
  "description": "FocusFlow — PC productivity & focus app",
  "author": "FocusFlow",
  "scripts": {
    "web:dev": "concurrently \"npm run server:dev\" \"npm run frontend:dev\"",
    "server:dev": "tsx watch server/index.ts",
    "frontend:dev": "vite --config vite.web.config.ts",
    "build": "vite build --config vite.web.config.ts",
    "start": "node dist-server/index.js"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.6",
    "dayjs": "^1.11.10",
    "express": "^4.22.1",
    "nanoid": "^3.3.7"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^20.19.40",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.33",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vite": "^5.4.21"
  }
}
